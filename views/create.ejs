<%- include('partials/head', { title }) %>
<%- include('partials/nav') %>

<main class="container">
  <div class="form-card">
    <header class="form-header">
      <div class="pill">Nuevo Candado</div>
      <h1>Configura tu entrega</h1>
      <p>Completa los detalles del trabajo y bloquea el acceso hasta que se confirme el pago.</p>
    </header>

    <form class="form" action="/api/locks" method="POST" enctype="multipart/form-data">
      <div class="form-section">
        <label for="title">Título del trabajo</label>
        <input type="text" id="title" name="title" placeholder="Ej: Diseño de Logotipo - Pack Final" required />
        <span class="helper">Este nombre aparecerá en el checkout de Stripe.</span>
      </div>

      <div class="form-section">
        <label for="description">Descripción (opcional)</label>
        <textarea id="description" name="description" placeholder="Detalla qué incluye esta entrega..."></textarea>
      </div>

      <div class="form-grid">
        <div class="form-section">
          <label for="price">Precio</label>
          <input type="number" id="price" name="price" step="0.01" min="0.01" placeholder="0.00" required />
        </div>
        <div class="form-section">
          <label for="currency">Moneda</label>
          <select id="currency" name="currency">
            <option value="eur">EUR (€)</option>
            <option value="usd">USD ($)</option>
            <option value="mxn">MXN ($)</option>
            <option value="gbp">GBP (£)</option>
          </select>
        </div>
      </div>

      <div class="form-section">
        <label for="client_email">Email del cliente (opcional)</label>
        <input type="email" id="client_email" name="client_email" placeholder="cliente@ejemplo.com" />
        <span class="helper">Se usará para pre-rellenar el formulario de pago.</span>
      </div>

      <div class="form-section">
        <label>Método de entrega</label>
        <div class="radio-row">
          <label class="radio-pill">
            <input type="radio" name="delivery_type" value="upload" checked />
            Subir archivo
          </label>
          <label class="radio-pill">
            <input type="radio" name="delivery_type" value="link" />
            Enlazar archivo
          </label>
        </div>
      </div>

      <div class="form-section" data-delivery-upload>
        <label for="file">Archivo final</label>
        <input type="file" id="file" name="file" />
        <span class="helper">Límite de 2GB. Se almacenará de forma segura.</span>
      </div>

      <div class="form-section" data-delivery-link style="display: none;">
        <label for="link_url">Enlace al archivo</label>
        <input type="url" id="link_url" name="link_url" placeholder="https://drive.google.com/..." />
        <span class="helper">Drive, Dropbox, Figma, etc. El cliente lo verá tras pagar.</span>
      </div>

      <div class="form-actions">
        <button class="btn primary large full-width" type="submit">Crear Candado de Pago</button>
      </div>
    </form>
  </div>
</main>

<script>
  // Simple toggle for delivery type
  const radios = document.querySelectorAll('input[name="delivery_type"]');
  const uploadBlock = document.querySelector('[data-delivery-upload]');
  const linkBlock = document.querySelector('[data-delivery-link]');

  radios.forEach(radio => {
    radio.addEventListener('change', (e) => {
      if (e.target.value === 'upload') {
        uploadBlock.style.display = 'block';
        linkBlock.style.display = 'none';
        document.getElementById('file').required = true;
        document.getElementById('link_url').required = false;
      } else {
        uploadBlock.style.display = 'none';
        linkBlock.style.display = 'block';
        document.getElementById('file').required = false;
        document.getElementById('link_url').required = true;
      }
    });
  });
  
  // Set initial required state
  document.getElementById('file').required = true;
</script>

<%- include('partials/footer') %>
